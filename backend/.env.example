# Local development — copy to .env and adjust as needed
DATABASE_URL=sqlite:///./marketmind.db
SECRET_KEY=dev-secret-change-in-production
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://logictrade.site,https://www.logictrade.site

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google AdSense
AD_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
AD_SLOT_PROBABILITY=1234567890
AD_SLOT_SIDEBAR=1234567891
AD_SLOT_FOOTER=1234567892

# Amazon Associates (India)
AMAZON_AFFILIATE_TAG=yourtag-21
AMAZON_AFFILIATE_REGION=in

# Razorpay — create a ₹999/month plan in dashboard, then paste IDs here
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_PLAN_ID=plan_XXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
SUBSCRIPTION_AMOUNT_INR=999
TRIAL_DAYS=7
