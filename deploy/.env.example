# SECURITY: Change these before deploying to production
SECRET_KEY=your-256-bit-secret-key-change-this
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Database (defaults match docker-compose)
DATABASE_URL=postgresql://marketmind:marketmind@db:5432/marketmind

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Google AdSense (update with your publisher ID)
NEXT_PUBLIC_AD_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
AD_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
AD_SLOT_PROBABILITY=1234567890
AD_SLOT_SIDEBAR=1234567891
